# Backend Environment Variables
# Copy this to .env and fill in values

APP_NAME="Plant Disease Prediction System"
DEBUG=false
LOG_LEVEL=INFO

# Model paths (relative to backend directory)
MODEL_SPECIES_PATH=models/species_efficientnet_b3.onnx
MODEL_DISEASE_PATH=models/disease_efficientnet_b3.onnx

# Image upload limits
MAX_IMAGE_SIZE_MB=10

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# Inference thresholds (0-1)
SPECIES_CONFIDENCE_THRESHOLD=0.40
DISEASE_CONFIDENCE_THRESHOLD=0.50
